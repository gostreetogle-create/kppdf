{
  "name": "kp-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "seed:admin": "ts-node-dev --respawn src/scripts/seed-admin.ts",
    "seed:owner": "ts-node-dev --respawn src/scripts/seed-owner.ts",
    "seed:demo": "ts-node-dev --respawn src/scripts/seed-demo.ts",
    "users:promote-admin": "ts-node-dev --respawn src/scripts/promote-all-admin.ts",
    "seed:products": "ts-node-dev --respawn src/scripts/seed-products.ts",
    "seed:products:update": "ts-node-dev --respawn src/scripts/seed-products.ts -- --mode=update",
    "media:trim-products": "ts-node-dev --respawn src/scripts/trim-product-images.ts"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.4.1",
    "multer": "^2.1.1",
    "puppeteer": "^24.42.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
