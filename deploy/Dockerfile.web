# Сборка Angular внутри Docker
FROM node:20-alpine AS build
WORKDIR /app
COPY frontend/package*.json ./
RUN npm ci
COPY frontend/ ./
RUN npm run build

# Nginx — только статика + конфиг
FROM nginx:1.27-alpine
COPY --from=build /app/dist/kppdf-frontend/browser /usr/share/nginx/html
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
