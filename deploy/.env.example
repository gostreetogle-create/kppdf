# Скопируй в deploy/.env и замени значения. Файл .env в git не коммитится.

# Домен для nginx server_name (можно: go.tiit www.go.tiit)
DOMAIN=go.tiit

# Порты
WEB_PORT=80
BACKEND_PORT=3000

# MongoDB
MONGO_DB=kp-app
# Если пусто, deploy.sh соберёт из MONGO_DB:
# mongodb://127.0.0.1:27017/<MONGO_DB>
MONGO_URI=

# CORS — origin фронтенда (браузер). '*' запрещён в production.
CORS_ORIGIN=https://go.tiit

# JWT — секрет подписи access token (обязательно в production, минимум 32 символа)
JWT_SECRET=replace_with_strong_random_secret_min_32_chars

# DaData API — поиск компании по ИНН (https://dadata.ru)
DADATA_TOKEN=ваш_токен_с_dadata.ru

# Где хранить медиафайлы на сервере
MEDIA_ROOT=/opt/kppdf/media
