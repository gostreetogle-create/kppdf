# Скопируй в deploy/.env и замени значения. Файл .env в git не коммитится.

# Порты
BACKEND_PORT=3000
WEB_PORT=8080

# MongoDB
MONGO_PORT=27017
MONGO_DB=kp-app

# CORS — origin фронтенда (браузер). '*' запрещён в production.
# Локально: CORS_ORIGIN=http://localhost:8080
# Прод: https://ваш-домен
CORS_ORIGIN=http://localhost:8080

# DaData API — поиск компании по ИНН (https://dadata.ru)
# Бесплатно: 10 000 запросов/день. Зарегистрируйся и получи токен.
DADATA_TOKEN=ваш_токен_с_dadata.ru
